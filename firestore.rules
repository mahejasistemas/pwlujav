rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // PERMITE LEER Y ESCRIBIR A CUALQUIERA (MODO DE PRUEBA/DESARROLLO)
      // Cambia esto a "if request.auth != null" cuando tengas la autenticación lista para producción.
      allow read, write: if true;
    }
  }
}